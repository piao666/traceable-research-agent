# Copy this file to .env for local development.
# Do not commit real secrets.

APP_ENV=local
APP_PHASE=traceable-research-agent

AUTH_ENABLED=false
DEMO_API_KEY=
AUTH_HEADER_NAME=X-API-Key
ALLOW_AUTH_DISABLED_IN_DEV=true

ASYNC_RUN_ENABLED=true
ASYNC_RUN_POLL_INTERVAL_SECONDS=1

TENANT_HEADER_NAME=X-Tenant-ID
USER_HEADER_NAME=X-User-ID
DEFAULT_TENANT_ID=demo
DEFAULT_USER_ID=local-user

EXTERNAL_TOOLS_DEFAULT_MODE=real
OFFLINE_MODE=false
ALLOW_MOCK_FALLBACK=false

GITHUB_TOOL_DEFAULT_MODE=public_api
GITHUB_TOKEN=
GITHUB_PUBLIC_API_ENABLED=true
GITHUB_SEARCH_CACHE_ENABLED=true
GITHUB_SEARCH_CACHE_PATH=workspace/cache/github_search_cache.json
GITHUB_SEARCH_CACHE_TTL_SECONDS=3600
GITHUB_PUBLIC_API_TIMEOUT_SECONDS=10
GITHUB_PUBLIC_API_MAX_RETRIES=2
GITHUB_PUBLIC_API_FALLBACK_TO_MOCK=false

TAVILY_API_KEY=
TAVILY_SEARCH_ENABLED=true
TAVILY_DEFAULT_MAX_RESULTS=5
TAVILY_TIMEOUT_SECONDS=15
TAVILY_MAX_RETRIES=2
TAVILY_FALLBACK_TO_MOCK=false

FILE_READER_ALLOWED_ROOTS=workspace/docs
FILE_READER_HITL_OUTSIDE_ALLOWED_ROOTS=true

MCP_READONLY_MODE=true
MCP_ADAPTER_MODE=github_tavily_readonly
MCP_ALLOW_WRITE_TOOLS=false
MCP_REMOTE_REGISTRY_ENABLED=false
MCP_REMOTE_SERVERS=
MCP_CHANNEL_READONLY_SERVERS=
MCP_CHANNEL_INTERACTIVE_SERVERS=
MCP_CHANNEL_WRITE_SERVERS=
MCP_BRIDGE_HOST=127.0.0.1
MCP_BRIDGE_PORT=9001
MCP_BRIDGE_ENABLED_PROVIDERS=firecrawl,exa,context7
MCP_BRIDGE_FAKE_MODE=true
MCP_BRIDGE_TIMEOUT_SECONDS=20
MCP_BRIDGE_MAX_RESULTS=20
MCP_BRIDGE_MAX_CONTENT_CHARS=12000
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
CONTEXT7_API_KEY=
CONTEXT7_BASE_URL=

PARALLEL_EXECUTION_ENABLED=false
PARALLEL_MAX_WORKERS=3
PARALLEL_GROUP_STRATEGY=independent_tools
PARALLEL_TIMEOUT_SECONDS=60

EXECUTION_MODE=planned
REACT_ENABLED=true
REACT_MAX_STEPS=8
REACT_SAME_TOOL_MAX_CALLS=3
REACT_LLM_PROVIDER=qwen
REACT_LLM_MODEL=qwen-plus
REACT_DECISION_STRICT_JSON=true
REACT_FALLBACK_TO_PLANNED=true
REACT_FINISH_ON_INVALID_DECISION=true

LLM_PLANNER_ENABLED=false
REPORT_GENERATION_MODE=deterministic
LLM_PROVIDER=qwen
LLM_PLANNER_MODE=auto
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_API_KEY=
QWEN_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
LLM_STRICT_JSON=true

RAG_EMBEDDING_BACKEND=deterministic
RAG_VECTOR_BACKEND=json
RAG_MODEL_PATH=E:\Models\bge-small-zh-v1.5
RAG_CHROMA_DIR=workspace/chroma
RAG_COLLECTION_NAME=traceable_research_docs
RAG_DEVICE=cpu
RAG_NORMALIZE_EMBEDDINGS=true
RAG_REAL_BACKEND_ENABLED=false
RAG_RETRIEVAL_MODE=hybrid
RAG_BM25_ENABLED=true
RAG_HYBRID_ENABLED=true
RAG_RRF_K=60
RAG_DENSE_CANDIDATE_MULTIPLIER=2
RAG_BM25_CANDIDATE_MULTIPLIER=2
RAG_CHUNK_EXPERIMENT_SIZES=256,512,1024
RAG_CHUNK_EXPERIMENT_OUTPUT=workspace/eval_outputs/rag_chunk_experiment_results.json

# LLM_PROVIDER can be deterministic, qwen, or deepseek.
# REPORT_GENERATION_MODE must be deterministic or llm. The default never calls
# an external model while generating reports, even when API keys are present.
# LLM_PLANNER_MODE can be deterministic, auto, or llm.
# Defaults keep the project runnable without keys when LLM_PLANNER_ENABLED=false.
# DeepSeek/Qwen keys must come from .env or environment variables only.
# GITHUB_TOKEN is optional; mock mode remains offline-safe without it.
# GitHub public API calls are GET-only. Mock fallback is opt-in.
# FILE_READER_ALLOWED_ROOTS is a semicolon-separated directory allowlist; relative
# entries are resolved from the repo root. Default workspace/docs keeps the
# offline demo runnable. Keep additional roots narrow, for example:
# FILE_READER_ALLOWED_ROOTS=workspace/docs;E:\Python\traceable-agent-materials
# Paths outside allowed roots require HITL approval for the exact file path only
# when FILE_READER_HITL_OUTSIDE_ALLOWED_ROOTS=true.
# The MCP server exposes read-only, side-effect-free tools by default.
# Optional remote MCP discovery is disabled unless MCP_REMOTE_REGISTRY_ENABLED=true.
# New remote MCP channel configs are opt-in when non-empty. Each entry supports
# name/base_url/transport/timeout_seconds/allowed_tools/blocked_tools/headers_env/channel.
# Deep Research Source Pack bridge. Start it with:
#   powershell -ExecutionPolicy Bypass -File scripts/start_mcp_source_pack.ps1 -Mode fake
# or:
#   powershell -ExecutionPolicy Bypass -File scripts/start_mcp_source_pack.ps1 -Mode real
# Keep this JSON on one line in .env files.
# MCP_CHANNEL_READONLY_SERVERS=[{"name":"source_pack","base_url":"http://127.0.0.1:9001/mcp","transport":"http_json_rpc","timeout_seconds":20,"allowed_tools":["firecrawl.search","firecrawl.scrape","firecrawl.map","firecrawl.extract","exa.web_search_exa","exa.web_fetch_exa","exa.web_search_advanced_exa","context7.resolve-library-id","context7.query-docs"],"blocked_tools":[],"headers_env":{},"channel":"readonly"}]
# Browser/playwright-like tools should use MCP_CHANNEL_INTERACTIVE_SERVERS and
# require HITL; write-capable servers should stay in MCP_CHANNEL_WRITE_SERVERS,
# which is discovered only for audit summary and not auto-registered.
# Example interactive channel:
# MCP_CHANNEL_INTERACTIVE_SERVERS=[{"name":"firecrawl_interactive","base_url":"http://127.0.0.1:9004/mcp","transport":"http_json_rpc","timeout_seconds":10,"allowed_tools":["interact"],"blocked_tools":[],"headers_env":{"Authorization":"FIRECRAWL_MCP_AUTH_HEADER"},"channel":"interactive"}]
# Planned execution is the stable default. ReAct is optional, bounded, and
# falls back to the persisted planned path when initialization fails.
# Day26 keeps deterministic/json as the lightweight default. Real model and
# vector backends are optional future modes and their runtime files are ignored.

# Real RAG optional mode:
# RAG_EMBEDDING_BACKEND=sentence_transformers
# RAG_VECTOR_BACKEND=chroma
# RAG_REAL_BACKEND_ENABLED=true
# RAG_MODEL_PATH=E:\Models\bge-small-zh-v1.5
# RAG_CHROMA_DIR=workspace/chroma
# RAG_COLLECTION_NAME=traceable_research_docs
# RAG_DEVICE=cpu
# RAG_NORMALIZE_EMBEDDINGS=true
