# Copy this file to .env for local development.
# Do not commit real secrets.

APP_ENV=local

LLM_PLANNER_ENABLED=false
LLM_PROVIDER=qwen
LLM_PLANNER_MODE=auto
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_API_KEY=
QWEN_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
LLM_STRICT_JSON=true

# LLM_PROVIDER can be deterministic, qwen, or deepseek.
# LLM_PLANNER_MODE can be deterministic, auto, or llm.
# Defaults keep the project runnable without keys when LLM_PLANNER_ENABLED=false.
# DeepSeek/Qwen keys must come from .env or environment variables only.
