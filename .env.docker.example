# Docker demo defaults. Copy to .env.docker for local overrides.
# Do not commit real API keys or tokens.

AUTH_ENABLED=false
EXECUTION_MODE=planned
LLM_PLANNER_ENABLED=false

GITHUB_TOKEN=
TAVILY_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=

RAG_REAL_BACKEND_ENABLED=false
RAG_EMBEDDING_BACKEND=deterministic
RAG_VECTOR_BACKEND=json
RAG_RETRIEVAL_MODE=dense

DOCKER_INIT_DEMO_DATA=true
STREAMLIT_API_BASE_URL=http://api:8000
